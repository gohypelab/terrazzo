require "terrazzo/base_dashboard"

class <%= class_name %>Dashboard < Terrazzo::BaseDashboard
  ATTRIBUTE_TYPES = {
<% attribute_types.each do |attr, type| -%>
<% if has_enum?(attr.to_s) -%>
    <%= attr %>: <%= type %>.with_options(collection: <%= enum_collection(attr.to_s).inspect %>),
<% else -%>
    <%= attr %>: <%= type %>,
<% end -%>
<% end -%>
  }.freeze

  COLLECTION_ATTRIBUTES = %i[
<% collection_attributes.each do |attr| -%>
    <%= attr %>
<% end -%>
  ].freeze

  SHOW_PAGE_ATTRIBUTES = %i[
<% show_page_attributes.each do |attr| -%>
    <%= attr %>
<% end -%>
  ].freeze

  FORM_ATTRIBUTES = %i[
<% form_attributes.each do |attr| -%>
    <%= attr %>
<% end -%>
  ].freeze

  # COLLECTION_FILTERS = {
  #   active: ->(resources) { resources.where(active: true) },
  #   recent: ->(resources) { resources.where("created_at > ?", 30.days.ago) },
  # }.freeze

  # Overwrite this method to customize how <%= file_name.pluralize.humanize.downcase %> are displayed
  # across all pages of the admin dashboard.
  #
  # def display_resource(resource)
  #   "<%= class_name %> ##{resource.id}"
  # end
end
